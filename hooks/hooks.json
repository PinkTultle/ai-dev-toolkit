{
  "$schema": "https://json.schemastore.org/claude-code-hooks.json",
  "description": "adt — AI Development Toolkit v0.4.0",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-check.sh $CLAUDE_FILE_PATH",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
